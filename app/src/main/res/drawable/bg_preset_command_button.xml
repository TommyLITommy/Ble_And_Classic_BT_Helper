<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/preset_btn_ripple">
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <solid android:color="@color/preset_btn_bg_pressed" />
                    <corners android:radius="@dimen/button_corner_radius" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/primary" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/preset_btn_bg_normal" />
                    <corners android:radius="@dimen/button_corner_radius" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/preset_btn_stroke" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
