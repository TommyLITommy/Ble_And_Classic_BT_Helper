<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.BleCore.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="Widget.BleCore.Button.Danger" parent="Widget.BleCore.Button">
        <item name="android:background">@drawable/bg_button_danger</item>
    </style>

    <style name="Widget.BleCore.MaterialButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.BleCore.MaterialButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.BleCore.ActionText" parent="">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
