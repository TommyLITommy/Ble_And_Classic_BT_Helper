<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/charItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/gatt_char_indent"
    android:layout_marginEnd="@dimen/gatt_service_card_margin_h"
    android:background="@drawable/bg_gatt_characteristic"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/tvCharacteristicName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="@color/color_main"
        android:textIsSelectable="true"
        android:textSize="14sp"
        tools:text="特征值名称" />

    <TextView
        android:id="@+id/tvCharacteristicUUID"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:singleLine="true"
        android:textColor="@color/text_secondary"
        android:textIsSelectable="true"
        android:textSize="12sp"
        tools:text="0000fff1-0000-1000-8000-00805f9b34fb" />

    <TextView
        android:id="@+id/tvCharacteristicProperties"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="@color/text_secondary"
        android:textIsSelectable="true"
        android:textSize="12sp"
        tools:text="Read, Write, Notify"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/llCharacteristicActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:minHeight="@dimen/gatt_action_height"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnReadData"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gatt_action_height"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="0dp"
            android:text="读数据"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <CheckBox
            android:id="@+id/cbNotify"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/gatt_action_height"
            android:gravity="center_vertical"
            android:checked="false"
            android:minHeight="@dimen/gatt_action_height"
            android:text="Notify"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <Button
            android:id="@+id/btnWriteData"
            android:layout_width="match_parent"
            android:layout_height="@dimen/gatt_action_height"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="0dp"
            android:text="@string/write_data"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <CheckBox
            android:id="@+id/cbIndicate"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/gatt_action_height"
            android:gravity="center_vertical"
            android:checked="false"
            android:minHeight="@dimen/gatt_action_height"
            android:text="Indicate"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="gone" />
    </LinearLayout>
</LinearLayout>
