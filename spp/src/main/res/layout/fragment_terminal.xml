<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="文件名:"
                android:textSize="11sp" />

            <AutoCompleteTextView
                android:id="@+id/filenameEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:minHeight="36dp"
                android:background="@drawable/bg_filename_edittext"
                android:hint="可选前缀，点选历史或输入新名称"
                android:textSize="11sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:includeFontPadding="true"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:completionThreshold="1"
                android:inputType="text" />

            <Button
                android:id="@+id/updateFilenameBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_terminal_outline_button"
                android:backgroundTint="@null"
                android:minHeight="36dp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:text="Update" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/shareButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_terminal_outline_button"
                android:backgroundTint="@null"
                android:minHeight="36dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:text="分享文件" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/save_rx_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:minHeight="32dp"
            android:paddingStart="2dp"
            android:text="同步保存接收数据（后台也写文件，单文件≤50MB）"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/payload_string_checkbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="32dp"
            android:paddingStart="2dp"
            android:text="Payload String打印（提取 MM payload 并以字符串显示）"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="11sp"
            android:textColor="#FF0000" />
    </LinearLayout>


    <!-- 状态显示 -->
<!--    <TextView-->
<!--        android:id="@+id/statusTextView"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:layout_marginTop="8dp"-->
<!--        android:textColor="#FF0000" />-->

    <ScrollView
        android:id="@+id/receive_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/receive_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:freezesText="true"
            android:padding="4dp"
            android:textSize="12sp"
            android:textAppearance="@style/TextAppearance.AppCompat.Medium" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:background="?android:attr/listDivider"
        android:layout_height="2dp" />

    <LinearLayout
        android:layout_margin="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/send_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:hint="HEX / 文本"
            android:inputType="textMultiLine|textNoSuggestions"
            android:maxLines="4"
            android:minHeight="40dp"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/clear_send_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="清空输入"
            app:srcCompat="@drawable/ic_clear_input_white_24dp" />

        <ImageButton
            android:id="@+id/edit_bytes_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="按字节编辑"
            app:srcCompat="@drawable/ic_edit_bytes_white_24dp" />

        <ImageButton
            android:id="@+id/dropdown_arrow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="预设命令"
            app:srcCompat="@drawable/ic_keyboard_arrow_down_white_24dp" />

        <ImageButton
            android:id="@+id/send_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="发送"
            app:srcCompat="@drawable/ic_send_white_24dp" />
    </LinearLayout>

</LinearLayout>

